<%- include('partials/head') %>
<%- include('partials/navbar') %>

<section class="section" style="padding-top: 140px;">
    <div class="section-head">
        <span class="section-eyebrow">About us</span>
        <h1 class="section-title" style="margin: 0 auto 16px; text-align: center;">
            Empowering traders with <span class="gradient-text">clarity</span>
        </h1>
        <p class="section-subtitle" style="text-align: center;">
            <%= site.name %> gives traders worldwide cutting-edge technology and expert guidance, built for confident decisions since 2024.
        </p>
    </div>

    <div class="feature-grid" style="margin-bottom: 60px;">
        <div class="feature-card" style="text-align: center;">
            <div class="feature-icon" style="margin: 0 auto 18px;"><i class="fas fa-shield-alt"></i></div>
            <h3>Secure Trading</h3>
            <p>Bank-level security with 256-bit encryption and two-factor authentication on every account.</p>
        </div>

        <div class="feature-card" style="text-align: center;">
            <div class="feature-icon" style="margin: 0 auto 18px; background: var(--bridge-dim); color: var(--bridge);"><i class="fas fa-chart-line"></i></div>
            <h3>Real-Time Data</h3>
            <p>Live price updates and advanced charting tools that keep every decision informed.</p>
        </div>

        <div class="feature-card" style="text-align: center;">
            <div class="feature-icon" style="margin: 0 auto 18px; background: var(--alert-dim); color: var(--alert);"><i class="fas fa-users"></i></div>
            <h3>Expert Community</h3>
            <p>Join 1M+ traders sharing strategies, insight, and market calls in real time.</p>
        </div>
    </div>

    <div class="cta-band" style="text-align: left; padding: 44px;">
        <span class="section-eyebrow">Our mission</span>
        <h2 style="margin-bottom: 14px;">Trading that's fair, transparent, and yours to control</h2>
        <p style="max-width: 640px;">
            We're building a platform that gives everyone, from first-time traders to seasoned professionals,
            the tools and honesty they need to trade successfully and safely. No hidden fees, no black-box pricing &mdash;
            just a clear view of the market and the controls to act on it.
        </p>
    </div>
</section>

<%- include('partials/footer') %>
