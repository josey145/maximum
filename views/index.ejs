<style>
    /* ==================== PRELOADER ==================== */
    .preloader {
        position: fixed;
        inset: 0;
        z-index: 5000;
        background: var(--void);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 18px;
        transition: opacity 0.5s ease, visibility 0.5s ease;
    }
    .preloader.hidden { opacity: 0; visibility: hidden; pointer-events: none; }

    .preloader-mark { position: relative; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; }
    .preloader-logo {
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 700;
        font-size: 20px;
        color: var(--signal);
    }
    .preloader-ring {
        position: absolute; inset: 0;
        transform: rotate(-90deg);
        animation: spinRing 1.4s linear infinite;
    }
    .preloader-ring circle {
        fill: none;
        stroke: var(--signal);
        stroke-width: 2;
        stroke-dasharray: 60 100;
        stroke-linecap: round;
    }
    @keyframes spinRing { to { transform: rotate(270deg); } }

    .preloader-label {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 11px;
        letter-spacing: 3px;
        color: var(--mist);
    }

    .preloader-bar {
        width: 140px; height: 3px;
        background: var(--surface-2);
        border-radius: 2px;
        overflow: hidden;
    }
    .preloader-bar span {
        display: block;
        height: 100%;
        width: 40%;
        background: linear-gradient(90deg, var(--signal), var(--bridge));
        border-radius: 2px;
        animation: barSlide 1.1s ease-in-out infinite;
    }
    @keyframes barSlide {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(350%); }
    }

    /* ==================== HERO VISUAL / MOCKUP IMAGE ==================== */
    .hero-visual {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 380px;
    }

    .hero-mockup-img {
        width: 100%;
        max-width: 620px;
        height: auto;
        display: block;
        position: relative;
        z-index: 1;
        filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.45));
    }

    /* Live price panel sits layered on top of the mockup image,
       positioned toward the lower-right like a floating widget */
    .hero-visual .hero-panel {
        position: absolute;
        bottom: -10px;
        right: 0;
        width: 260px;
        z-index: 2;
    }

    @media (max-width: 900px) {
        .hero-visual { min-height: unset; flex-direction: column; gap: 20px; }
        .hero-visual .hero-panel {
            position: static;
            width: 100%;
        }
    }

    /* ==================== BOTTOM PRICE TICKER ==================== */
    .price-ticker {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 2000;
        height: 42px;
        background: var(--surface-1, #0d1117);
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        overflow: hidden;
        display: flex;
        align-items: center;
    }
    .price-ticker-track {
        display: flex;
        align-items: center;
        white-space: nowrap;
        animation: tickerScroll 30s linear infinite;
        will-change: transform;
    }
    .price-ticker:hover .price-ticker-track { animation-play-state: paused; }

    @keyframes tickerScroll {
        0%   { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }

    .ticker-item {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0 24px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 12.5px;
        color: var(--mist, #a3adc2);
        border-right: 1px solid rgba(255, 255, 255, 0.06);
    }
    .ticker-icon { font-size: 14px; }
    .ticker-sym { color: #eef1f8; font-weight: 600; }
    .ticker-price { color: #eef1f8; }
    .ticker-change.positive { color: var(--signal, #00e6a0); }
    .ticker-change.negative { color: #ff5c72; }

    /* keep page content from hiding behind the fixed ticker bar */
    body { padding-bottom: 42px; }

    @media (max-width: 600px) {
        .ticker-item { padding: 0 16px; font-size: 11.5px; }
    }

    /* ==================== SCROLL / ENTRANCE REVEAL ==================== */
    .reveal {
        opacity: 0;
        transform: translateY(22px);
        transition: opacity 0.7s ease, transform 0.7s ease;
        transition-delay: var(--delay, 0s);
    }
    .reveal.in-view { opacity: 1; transform: translateY(0); }

    @media (prefers-reduced-motion: reduce) {
        .preloader { display: none; }
        .reveal, .reveal.in-view { opacity: 1; transform: none; transition: none; }
    }
</style>

<script>
    // ---------- Bottom ticker: duplicate items for seamless scroll ----------
    (function () {
        const track = document.getElementById('priceTickerTrack');
        if (track) {
            track.innerHTML += track.innerHTML; // duplicate once so the 50% translate loops seamlessly
        }
    })();

    // ---------- Preloader ----------
    (function () {
        const pre = document.getElementById('preloader');
        function hidePreloader() {
            pre.classList.add('hidden');
            document.body.classList.add('loaded');
        }
        if (document.readyState === 'complete') {
            setTimeout(hidePreloader, 300);
        } else {
            window.addEventListener('load', function () { setTimeout(hidePreloader, 300); });
        }
        // safety net so a slow asset never traps the visitor behind the preloader
        setTimeout(hidePreloader, 4000);
    })();

    // ---------- Hero entrance ----------
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.reveal-load').forEach(function (el) {
            requestAnimationFrame(function () { el.classList.add('in-view'); });
        });
    });

    // ---------- Scroll reveal ----------
    (function () {
        const targets = document.querySelectorAll('.reveal:not(.reveal-load)');
        if (!('IntersectionObserver' in window) || targets.length === 0) {
            targets.forEach(function (el) { el.classList.add('in-view'); });
            return;
        }
        const io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('in-view');
                    io.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
        targets.forEach(function (el) { io.observe(el); });
    })();

    const ctx = document.getElementById('priceChart').getContext('2d');

    const gradient = ctx.createLinearGradient(0, 0, 0, 220);
    gradient.addColorStop(0, 'rgba(0, 230, 160, 0.25)');
    gradient.addColorStop(1, 'rgba(0, 230, 160, 0)');

    const chart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: [],
            datasets: [{
                label: 'BTC Price',
                data: [],
                borderColor: '#00e6a0',
                backgroundColor: gradient,
                borderWidth: 2.5,
                fill: true,
                tension: 0.4,
                pointRadius: 0,
                pointHoverRadius: 5
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { display: false },
                y: {
                    display: true,
                    grid: { color: 'rgba(255, 255, 255, 0.05)' },
                    ticks: {
                        color: '#565f75',
                        callback: function (value) { return '$' + value.toLocaleString(); }
                    }
                }
            },
            interaction: { intersect: false, mode: 'index' }
        }
    });

    const socket = io();

    socket.on('btcPrice', (data) => {
        document.getElementById('currentPrice').textContent = '$' + data.price.toLocaleString();

        const changeEl = document.getElementById('priceChange');
        const changePercent = data.change24h.toFixed(2);
        document.getElementById('changePercent').textContent = Math.abs(changePercent) + '%';

        if (data.change24h >= 0) {
            changeEl.className = 'price-change positive';
            changeEl.innerHTML = '<i class="fas fa-arrow-up"></i> <span id="changePercent">' + changePercent + '%</span>';
        } else {
            changeEl.className = 'price-change negative';
            changeEl.innerHTML = '<i class="fas fa-arrow-down"></i> <span id="changePercent">' + Math.abs(changePercent) + '%</span>';
        }

        if (chart.data.labels.length > 50) {
            chart.data.labels.shift();
            chart.data.datasets[0].data.shift();
        }
        chart.data.labels.push(chart.data.labels.length);
        chart.data.datasets[0].data.push(data.price);
        chart.update('none');

        // keep every ticker-bar Bitcoin entry (original + duplicated) in sync
        document.querySelectorAll('#tickerBtcPrice').forEach(function (el) {
            el.textContent = data.price.toLocaleString();
        });
        document.querySelectorAll('#tickerBtcChange').forEach(function (el) {
            el.textContent = (data.change24h >= 0 ? '+' : '') + data.change24h.toFixed(2) + '%';
            el.className = 'ticker-change ' + (data.change24h >= 0 ? 'positive' : 'negative');
        });
    });

    socket.on('priceHistory', (history) => {
        if (history.length > 0) {
            chart.data.labels = history.map((_, i) => i);
            chart.data.datasets[0].data = history.map(h => h.price);
            chart.update();
        }
    });
</script>

<!-- ============== CHAPORT LIVE CHAT ============== -->
<script>
    (function () {
        var w = window, d = document;
        function l() {
            var s = d.createElement('script');
            s.type = 'text/javascript';
            s.async = true;
            s.src = 'https://app.chaport.com/javascripts/insert.js';
            var ss = d.getElementsByTagName('script')[0];
            ss.parentNode.insertBefore(s, ss);
        }
        if (w.chaportConfig) {
            l();
        } else {
            w.chaportConfig = {
                appId: 'YOUR_CHAPORT_APP_ID' // <-- replace with the App ID from your Chaport dashboard
            };
            l();
        }
    })();
</script>
