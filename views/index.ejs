<script>
    const ctx = document.getElementById('priceChart').getContext('2d');

    const gradient = ctx.createLinearGradient(0, 0, 0, 220);
    gradient.addColorStop(0, 'rgba(0, 230, 160, 0.25)');
    gradient.addColorStop(1, 'rgba(0, 230, 160, 0)');

    const chart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: [],
            datasets: [{
                label: 'BTC Price',
                data: [],
                borderColor: '#00e6a0',
                backgroundColor: gradient,
                borderWidth: 2.5,
                fill: true,
                tension: 0.4,
                pointRadius: 0,
                pointHoverRadius: 5
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { display: false },
                y: {
                    display: true,
                    grid: { color: 'rgba(255, 255, 255, 0.05)' },
                    ticks: {
                        color: '#565f75',
                        callback: function (value) { return '$' + value.toLocaleString(); }
                    }
                }
            },
            interaction: { intersect: false, mode: 'index' }
        }
    });

    const socket = io();

    socket.on('btcPrice', (data) => {
        document.getElementById('currentPrice').textContent = '$' + data.price.toLocaleString();

        const changeEl = document.getElementById('priceChange');
        const changePercent = data.change24h.toFixed(2);
        document.getElementById('changePercent').textContent = Math.abs(changePercent) + '%';

        if (data.change24h >= 0) {
            changeEl.className = 'price-change positive';
            changeEl.innerHTML = '<i class="fas fa-arrow-up"></i> <span id="changePercent">' + changePercent + '%</span>';
        } else {
            changeEl.className = 'price-change negative';
            changeEl.innerHTML = '<i class="fas fa-arrow-down"></i> <span id="changePercent">' + Math.abs(changePercent) + '%</span>';
        }

        if (chart.data.labels.length > 50) {
            chart.data.labels.shift();
            chart.data.datasets[0].data.shift();
        }
        chart.data.labels.push(chart.data.labels.length);
        chart.data.datasets[0].data.push(data.price);
        chart.update('none');
    });

    socket.on('priceHistory', (history) => {
        if (history.length > 0) {
            chart.data.labels = history.map((_, i) => i);
            chart.data.datasets[0].data = history.map(h => h.price);
            chart.update();
        }
    });
</script>
