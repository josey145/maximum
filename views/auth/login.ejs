<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="auth-page">
    <div class="auth-container animate-fade-in">
        <div class="auth-header">
            <h1 class="auth-title">Welcome Back</h1>
            <p class="auth-subtitle">Enter your credentials to access your account</p>
        </div>

        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> <%= success_msg %>
            </div>
        <% } %>

        <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-error">
                <i class="fas fa-exclamation-circle"></i> <%= error_msg %>
            </div>
        <% } %>

        <% if (site && site.maintenance_mode) { %>
            <div class="maintenance-notice">
                <i class="fas fa-tools"></i>
                <div>
                    <div class="maintenance-title">Platform Under Maintenance</div>
                    <div class="maintenance-body"><%= site.name %> is currently undergoing maintenance. Admin access only at this time.</div>
                </div>
            </div>
        <% } %>

        <div class="auth-form">
            <form action="/login" method="POST">
                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <div class="input-wrap">
                        <i class="fas fa-envelope"></i>
                        <input type="email" name="email" class="form-input" placeholder="name@example.com" required style="padding-left: 48px;">
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Password</label>
                    <div class="input-wrap">
                        <i class="fas fa-lock"></i>
                        <input type="password" name="password" class="form-input" placeholder="••••••••" required style="padding-left: 48px;">
                    </div>
                </div>

                <div class="login-row">
                    <label class="remember-label">
                        <input type="checkbox" name="remember">
                        Remember me
                    </label>
                    <a href="/forgot-password" class="forgot-link">Forgot password?</a>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%;">
                    <i class="fas fa-sign-in-alt"></i>
                    Sign In
                </button>
            </form>

            <div class="or-divider">Or continue with</div>

            <div style="display: flex; gap: 12px; margin-top: 16px;">
                <button type="button" class="btn btn-outline" style="flex: 1;">
                    <i class="fab fa-google"></i>
                </button>
                <button type="button" class="btn btn-outline" style="flex: 1;">
                    <i class="fab fa-github"></i>
                </button>
            </div>
        </div>

        <div class="auth-footer">
            Don't have an account? <a href="/register">Create one now</a>
        </div>
    </div>
</div>

<style>
    .auth-page .input-wrap { position: relative; }
    .auth-page .input-wrap i {
        position: absolute;
        left: 16px; top: 50%;
        transform: translateY(-50%);
        color: var(--mist-dim);
    }

    .maintenance-notice {
        background: rgba(245, 185, 66, 0.1);
        border: 1px solid var(--warning);
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 20px;
        display: flex;
        gap: 10px;
        align-items: flex-start;
    }
    .maintenance-notice i { color: var(--warning); margin-top: 2px; }
    .maintenance-title { color: var(--warning); font-weight: 600; font-size: 13px; margin-bottom: 4px; font-family: 'Space Grotesk', sans-serif; }
    .maintenance-body { color: var(--mist); font-size: 12px; }

    .login-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }
    .remember-label {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        color: var(--mist);
        font-size: 14px;
    }
    .remember-label input { accent-color: var(--signal); }
    .forgot-link { color: var(--signal); text-decoration: none; font-size: 14px; font-weight: 500; }

    .or-divider {
        text-align: center;
        margin-top: 24px;
        color: var(--mist-dim);
        font-size: 13px;
        position: relative;
    }
</style>

<%- include('../partials/footer') %>
