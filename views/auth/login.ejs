<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="auth-page">
    <div class="auth-container animate-fade-in">
        <div class="auth-header">
            <h1 class="auth-title">Welcome Back</h1>
            <p class="auth-subtitle">Enter your credentials to access your account</p>
        </div>

        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> <%= success_msg %>
            </div>
        <% } %>

        <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-error">
                <i class="fas fa-exclamation-circle"></i> <%= error_msg %>
            </div>
        <% } %>

        <div class="auth-form">
            <form action="/login" method="POST">
                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <div style="position: relative;">
                        <i class="fas fa-envelope" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #52525b;"></i>
                        <input type="email" name="email" class="form-input" placeholder="name@example.com" required style="padding-left: 48px;">
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Password</label>
                    <div style="position: relative;">
                        <i class="fas fa-lock" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #52525b;"></i>
                        <input type="password" name="password" class="form-input" placeholder="••••••••" required style="padding-left: 48px;">
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; color: var(--text-secondary); font-size: 14px;">
                        <input type="checkbox" name="remember" style="accent-color: var(--accent-purple);">
                        Remember me
                    </label>
                    <a href="/forgot-password" style="color: var(--accent-purple); text-decoration: none; font-size: 14px; font-weight: 500;">Forgot password?</a>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%;">
                    <i class="fas fa-sign-in-alt"></i>
                    Sign In
                </button>
            </form>

            <div style="text-align: center; margin-top: 24px; color: var(--text-secondary); font-size: 14px;">
                Or continue with
            </div>

            <div style="display: flex; gap: 12px; margin-top: 16px;">
                <button type="button" class="btn btn-outline" style="flex: 1;">
                    <i class="fab fa-google"></i>
                </button>
                <button type="button" class="btn btn-outline" style="flex: 1;">
                    <i class="fab fa-github"></i>
                </button>
            </div>
        </div>

        <div class="auth-footer">
            Don't have an account? <a href="/register">Create one now</a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>