<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1><%= siteName %></h1>
            <p>Create new password</p>
        </div>

        <% if (messages.error && messages.error.length > 0) { %>
            <div class="alert alert-error">
                <i class="fas fa-exclamation-circle"></i> <%= messages.error[0] %>
            </div>
        <% } %>

        <form action="/reset-password" method="POST" class="auth-form">
            <input type="hidden" name="token" value="<%= token %>">
            
            <div class="form-group">
                <label><i class="fas fa-lock"></i> New Password</label>
                <input type="password" name="password" placeholder="Min 8 characters" minlength="8" required>
            </div>

            <div class="form-group">
                <label><i class="fas fa-lock"></i> Confirm Password</label>
                <input type="password" name="confirmPassword" placeholder="Re-enter password" minlength="8" required>
            </div>

            <button type="submit" class="btn btn-primary btn-block">
                <i class="fas fa-key"></i> Reset Password
            </button>
        </form>

        <div class="auth-footer">
            <p>Back to <a href="/login">Login</a></p>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>