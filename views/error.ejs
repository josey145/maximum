<!-- views/error.ejs -->
<%- include('partials/head', { title: typeof title !== 'undefined' ? title : 'Error' }) %>

<div style="min-height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 24px;">
    <div style="font-size: 80px; margin-bottom: 24px;">⚠️</div>
    <h1 style="font-size: 24px; margin-bottom: 16px; color: #f4f4f5;">
        <%= typeof message !== 'undefined' ? message : 'Something went wrong' %>
    </h1>
    <a href="/dashboard" style="color: #8b5cf6; text-decoration: none;">Go to Dashboard</a>
</div>