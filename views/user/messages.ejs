<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<style>
.inbox-container {
    max-width: 900px;
    margin: 0 auto;
}

.inbox-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
}

.unread-badge-large {
    background: #ef4444;
    color: white;
    padding: 4px 14px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 700;
}

.messages-list {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
}

.message-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px 24px;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
}

.message-card:last-child {
    border-bottom: none;
}

.message-card:hover {
    background: rgba(139, 92, 246, 0.03);
}

.message-card.unread {
    background: rgba(139, 92, 246, 0.08);
    border-left: 3px solid #8b5cf6;
}

.message-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
}

.icon-warning { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
.icon-pending { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
.icon-welcome { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
.icon-general { background: rgba(139, 92, 246, 0.15); color: #8b5cf6; }

.message-info {
    flex: 1;
    min-width: 0;
}

.message-top {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 6px;
}

.message-subject {
    font-weight: 700;
    font-size: 16px;
    color: var(--text-primary);
    margin: 0;
}

.unread-dot {
    width: 8px;
    height: 8px;
    background: #ef4444;
    border-radius: 50%;
    flex-shrink: 0;
}

.message-preview {
    color: var(--text-secondary);
    font-size: 14px;
    margin: 0 0 8px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.message-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 12px;
    color: var(--text-secondary);
}

.message-meta span {
    display: flex;
    align-items: center;
    gap: 4px;
}

.empty-state {
    text-align: center;
    padding: 60px 24px;
    color: var(--text-secondary);
}

.empty-state i {
    font-size: 64px;
    margin-bottom: 16px;
    opacity: 0.5;
}
</style>

<div class="dashboard">
    <div class="inbox-header">
        <div>
            <h1 class="dashboard-title">
                <i class="fas fa-inbox" style="color: #8b5cf6;"></i> My Messages
            </h1>
            <p style="color: var(--text-secondary);">Communications from the support team</p>
        </div>
        <% if (unreadCount > 0) { %>
        <div class="unread-badge-large">
            <%= unreadCount %> unread
        </div>
        <% } %>
    </div>

    <div class="inbox-container">
        <% if (messages.length === 0) { %>
        <div class="messages-list">
            <div class="empty-state">
                <i class="fas fa-inbox"></i>
                <h3>No messages yet</h3>
                <p>When you receive messages from our team, they'll appear here.</p>
            </div>
        </div>
        <% } else { %>
        <div class="messages-list">
            <% messages.forEach(msg => { %>
            <a href="/messages/<%= msg.id %>" class="message-card <%= msg.status === 'unread' ? 'unread' : '' %>">
                <div class="message-icon icon-<%= msg.type %>">
                    <% if (msg.type === 'warning') { %><i class="fas fa-exclamation-triangle"></i><% } %>
                    <% if (msg.type === 'pending') { %><i class="fas fa-clock"></i><% } %>
                    <% if (msg.type === 'welcome') { %><i class="fas fa-hand-sparkles"></i><% } %>
                    <% if (msg.type === 'general') { %><i class="fas fa-envelope"></i><% } %>
                </div>
                <div class="message-info">
                    <div class="message-top">
                        <h3 class="message-subject"><%= msg.subject %></h3>
                        <% if (msg.status === 'unread') { %>
                        <span class="unread-dot"></span>
                        <% } %>
                    </div>
                    <p class="message-preview"><%= msg.message.substring(0, 100) %>...</p>
                    <div class="message-meta">
                        <span><i class="fas fa-user-shield"></i> <%= msg.admin_username %></span>
                        <span><i class="fas fa-clock"></i> <%= new Date(msg.created_at).toLocaleString() %></span>
                        <% if (msg.reply_count > 0) { %>
                        <span style="color: #3b82f6;"><i class="fas fa-reply"></i> <%= msg.reply_count %> replies</span>
                        <% } %>
                    </div>
                </div>
            </a>
            <% }) %>
        </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>