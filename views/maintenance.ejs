<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Under Maintenance — <%= site.name %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: #0a0a0f;
            color: #f4f4f5;
            font-family: Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .container {
            max-width: 520px;
            width: 100%;
            text-align: center;
        }

        .logo {
            font-size: 28px;
            font-weight: 800;
            letter-spacing: 3px;
            background: linear-gradient(135deg, #8b5cf6, #6d28d9);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 40px;
        }

        .icon-wrap {
            width: 100px;
            height: 100px;
            background: rgba(139, 92, 246, 0.1);
            border: 1px solid rgba(139, 92, 246, 0.3);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 32px;
            animation: pulse 2s infinite;
        }

        .icon-wrap i {
            font-size: 42px;
            color: #8b5cf6;
        }

        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.3); }
            50% { box-shadow: 0 0 0 20px rgba(139, 92, 246, 0); }
        }

        h1 {
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 16px;
            color: #f4f4f5;
        }

        p {
            color: #a1a1aa;
            font-size: 15px;
            line-height: 1.7;
            margin-bottom: 40px;
        }

        .contact-box {
            background: #111118;
            border: 1px solid #1e1e2e;
            border-radius: 16px;
            padding: 28px;
            margin-bottom: 32px;
        }

        .contact-box h3 {
            font-size: 13px;
            font-weight: 600;
            color: #52525b;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 20px;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 0;
            border-bottom: 1px solid #1e1e2e;
            text-decoration: none;
            color: #f4f4f5;
            transition: color 0.2s;
        }

        .contact-item:last-child { border-bottom: none; }
        .contact-item:hover { color: #8b5cf6; }

        .contact-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .contact-label {
            font-size: 11px;
            color: #52525b;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .contact-value {
            font-size: 14px;
            font-weight: 500;
        }

        .footer {
            color: #3f3f5a;
            font-size: 12px;
        }

        /* Animated dots */
        .dots::after {
            content: '';
            animation: dots 1.5s steps(3, end) infinite;
        }

        @keyframes dots {
            0%   { content: ''; }
            33%  { content: '.'; }
            66%  { content: '..'; }
            100% { content: '...'; }
        }
    </style>
</head>
<body>
    <div class="container">

        <div class="logo"><%= site.name.toUpperCase() %></div>

        <div class="icon-wrap">
            <i class="fas fa-wrench"></i>
        </div>

        <h1>We'll Be Right Back</h1>
        <p>
            <%= site.name %> is currently undergoing scheduled maintenance<span class="dots"></span><br>
            We're working hard to improve your experience. Thank you for your patience.
        </p>

        <% if (site.support_email || site.support_phone || site.support_whatsapp) { %>
        <div class="contact-box">
            <h3>Need urgent help? Contact us</h3>

            <% if (site.support_email) { %>
            <a href="mailto:<%= site.support_email %>" class="contact-item">
                <div class="contact-icon" style="background: rgba(59,130,246,0.1); color: #3b82f6;">
                    <i class="fas fa-envelope"></i>
                </div>
                <div>
                    <div class="contact-label">Email</div>
                    <div class="contact-value"><%= site.support_email %></div>
                </div>
            </a>
            <% } %>

            <% if (site.support_phone) { %>
            <a href="tel:<%= site.support_phone %>" class="contact-item">
                <div class="contact-icon" style="background: rgba(139,92,246,0.1); color: #8b5cf6;">
                    <i class="fas fa-phone"></i>
                </div>
                <div>
                    <div class="contact-label">Phone</div>
                    <div class="contact-value"><%= site.support_phone %></div>
                </div>
            </a>
            <% } %>

            <% if (site.support_whatsapp) { %>
            <a href="https://wa.me/<%= site.support_whatsapp.replace(/\D/g, '') %>" 
               target="_blank" class="contact-item">
                <div class="contact-icon" style="background: rgba(34,197,94,0.1); color: #22c55e;">
                    <i class="fab fa-whatsapp"></i>
                </div>
                <div>
                    <div class="contact-label">WhatsApp</div>
                    <div class="contact-value"><%= site.support_whatsapp %></div>
                </div>
            </a>
            <% } %>
        </div>
        <% } %>

        <div class="footer">
            &copy; <%= site.current_year %> <%= site.name %> · All rights reserved
        </div>
    </div>
</body>
</html>