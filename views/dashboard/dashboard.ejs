<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<link rel="stylesheet" href="../css/dashboard.css">

<div class="dashboard-container">

    <!-- Greeting -->
    <div class="welcome-header">
        <div>
            <h1 class="welcome-title">Welcome back, <%= user.username %></h1>
            <p class="welcome-subtitle">
                <% if (user.account_verified) { %>
                    <i class="fas fa-check-circle"></i> Verified Account
                <% } else { %>
                    <i class="fas fa-clock"></i> Account Pending Verification
                <% } %>
            </p>
        </div>
    </div>

    <!-- Top grid: Balance (light card) + Portfolio / Positions (dark cards) -->
    <div class="top-grid">

        <!-- Available Balance -->
        <div class="balance-card">
            <div>
                <div class="balance-label">Available Balance</div>
                <div class="balance-amount"><%= balanceFormatted %></div>
                <div class="balance-currency">Currency: <%= user.currency || 'USD' %></div>
            </div>

            <div class="quick-actions">
                <a href="/investments" class="action-btn action-btn-deposit">
                    <i class="fas fa-plus"></i> Invest
                </a>
                <a href="/transactions/withdraw/verify" class="action-btn action-btn-withdraw">
                    <i class="fas fa-minus"></i> Withdraw
                </a>
            </div>
        </div>

        <!-- Portfolio Value + Open Positions -->
        <div class="side-stack">
            <div class="mini-card">
                <div class="mini-card-top">
                    <div>
                        <div class="mini-card-label">Portfolio Value</div>
                        <div class="mini-card-value"><%= totalValueFormatted %></div>
                    </div>
                    <div class="mini-card-icon purple">
                        <i class="fas fa-chart-pie"></i>
                    </div>
                </div>
                <% if (tradeStats.winRate > 0) { %>
                    <div class="mini-card-change <%= parseFloat(unrealizedPnLFormatted.replace(/[^0-9.-]/g, '')) >= 0 ? 'positive' : 'negative' %>">
                        <i class="fas fa-arrow-<%= parseFloat(unrealizedPnLFormatted.replace(/[^0-9.-]/g, '')) >= 0 ? 'up' : 'down' %>"></i>
                        Unrealized: <%= unrealizedPnLFormatted %>
                    </div>
                <% } %>
            </div>

            <div class="mini-card">
                <div class="mini-card-top">
                    <div>
                        <div class="mini-card-value"><%= tradeStats.openPositions %></div>
                        <div class="mini-card-sub">open positions</div>
                    </div>
                    <div class="mini-card-icon green">
                        <i class="fas fa-arrow-trend-up"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Extra stats (P&L / Deposits) -->
    <div class="card">
        <div class="investment-details" style="grid-template-columns: repeat(2, 1fr); gap: 16px;">
            <div class="investment-detail">
                <span class="investment-label">Total Profit / Loss</span>
                <span class="investment-value <%= parseFloat(totalPnLFormatted.replace(/[^0-9.-]/g, '')) >= 0 ? 'pnl-positive' : 'pnl-negative' %>">
                    <%= parseFloat(totalPnLFormatted.replace(/[^0-9.-]/g, '')) >= 0 ? '+' : '' %><%= totalPnLFormatted %>
                </span>
                <span class="mini-card-sub"><%= tradeStats.winningTrades %> wins / <%= tradeStats.losingTrades %> losses (<%= tradeStats.winRate %>%)</span>
            </div>
            <div class="investment-detail">
                <span class="investment-label">Total Deposits</span>
                <span class="investment-value" style="color: var(--green);">
                    <%= typeof totalDepositsFormatted !== 'undefined' ? totalDepositsFormatted : '$0.00' %>
                </span>
                <span class="mini-card-sub"><%= typeof totalDepositsCount !== 'undefined' ? totalDepositsCount : 0 %> deposits</span>
            </div>
        </div>
    </div>

    <!-- Live Bitcoin Price -->
    <div class="price-ticker">
        <div class="ticker-header">
            <span class="ticker-title">Live Bitcoin Price</span>
            <span class="live-badge">
                <span class="live-dot"></span>
                LIVE
            </span>
        </div>
        <div class="ticker-price">
            <span class="ticker-amount" id="btcPrice">$0.00</span>
            <span class="ticker-change positive" id="btcChange">
                <i class="fas fa-arrow-up"></i> 0.00%
            </span>
        </div>
    </div>

    <!-- WARNING / MESSAGE ALERTS -->
    <% if (typeof warnings !== 'undefined' && warnings && warnings.length > 0) { %>
    <div class="warning-alerts">
        <% warnings.forEach(warning => {
            let iconColor, bgColor, borderColor;
            switch(warning.type) {
                case 'warning':
                    iconColor = '#f43f5e'; bgColor = 'rgba(244, 63, 94, 0.12)'; borderColor = '#f43f5e'; break;
                case 'pending':
                    iconColor = '#f59e0b'; bgColor = 'rgba(245, 158, 11, 0.12)'; borderColor = '#f59e0b'; break;
                case 'welcome':
                    iconColor = '#22c55e'; bgColor = 'rgba(34, 197, 94, 0.12)'; borderColor = '#22c55e'; break;
                case 'general':
                default:
                    iconColor = '#3b82f6'; bgColor = 'rgba(59, 130, 246, 0.12)'; borderColor = '#3b82f6';
            }
            const iconClass = warning.type === 'warning' ? 'fa-exclamation-triangle' :
                             warning.type === 'pending' ? 'fa-clock' :
                             warning.type === 'welcome' ? 'fa-hand-sparkles' : 'fa-envelope';
        %>
        <div class="warning-card" id="warning-<%= warning.id %>" style="border-left-color: <%= borderColor %>;">
            <div class="warning-icon" style="background: <%= bgColor %>; color: <%= iconColor %>;">
                <i class="fas <%= iconClass %>"></i>
            </div>
            <div class="warning-content">
                <h3 class="warning-title" style="color: <%= iconColor %>;"><%= warning.title %></h3>
                <p class="warning-text"><%= warning.message %></p>
                <div class="warning-actions">
                    <a href="<%= warning.action_url || '/messages' %>" class="warning-btn" style="background: <%= iconColor %>; color: white;">
                        <i class="fas fa-envelope-open"></i> <%= warning.action_text || 'Read' %>
                    </a>
                    <button class="warning-btn secondary" onclick="clearMessage('<%= warning.id %>')">
                        <i class="fas fa-times"></i> Clear
                    </button>
                </div>
            </div>
            <button class="dismiss-btn" onclick="clearMessage('<%= warning.id %>')" title="Clear" style="color: <%= iconColor %>;">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <% }) %>
    </div>
    <% } %>

    <!-- Active Positions -->
    <% if (activeInvestments && activeInvestments.length > 0) { %>
    <div class="card">
        <h3 class="section-title">
            <i class="fas fa-briefcase"></i>
            Active Positions (<%= activeInvestments.length %>)
        </h3>

        <% activeInvestments.forEach(trade => { %>
        <div class="investment-card">
            <div class="investment-header">
                <div>
                    <span class="investment-pair"><%= trade.pair_symbol || trade.symbol %></span>
                    <span style="font-size: 11px; color: var(--text-faint); margin-left: 8px;"><%= trade.pair_name %></span>
                </div>
                <span class="investment-direction direction-<%= trade.direction %>">
                    <%= trade.direction.toUpperCase() %>
                </span>
            </div>
            <div class="investment-details">
                <div class="investment-detail">
                    <span class="investment-label">Entry Price</span>
                    <span class="investment-value">
                        <%= formatCurrency(trade.converted_entry_price || trade.entry_price, displayCurrency) %>
                    </span>
                </div>
                <div class="investment-detail">
                    <span class="investment-label">Lot Size</span>
                    <span class="investment-value"><%= trade.lot_size %></span>
                </div>
                <div class="investment-detail">
                    <span class="investment-label">P&L</span>
                    <span class="investment-value <%= parseFloat(trade.converted_profit_loss || trade.profit_loss) >= 0 ? 'pnl-positive' : 'pnl-negative' %>">
                        <%= formatCurrency(trade.converted_profit_loss || trade.profit_loss, displayCurrency) %>
                    </span>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
    <% } %>

    <!-- Menu Grid -->
    <div class="menu-grid">
        <a href="/profile" class="menu-item">
            <div class="menu-icon" style="background: rgba(139,92,246,0.12); color: #8b5cf6;">
                <i class="fas fa-user"></i>
            </div>
            <div class="menu-title">Profile</div>
            <div class="menu-desc">Edit info</div>
        </a>

        <a href="/transactions/history" class="menu-item">
            <div class="menu-icon" style="background: rgba(245, 158, 11, 0.12); color: #f59e0b;">
                <i class="fas fa-history"></i>
            </div>
            <div class="menu-title">History</div>
            <div class="menu-desc">Transactions</div>
        </a>

        <a href="/trading" class="menu-item">
            <div class="menu-icon" style="background: rgba(34,197,94,0.12); color: #22c55e;">
                <i class="fas fa-exchange-alt"></i>
            </div>
            <div class="menu-title">Trading</div>
            <div class="menu-desc">Forex & Crypto</div>
        </a>

        <a href="/investments" class="menu-item">
            <div class="menu-icon" style="background: rgba(59,130,246,0.12); color: #3b82f6;">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="menu-title">Investments</div>
            <div class="menu-desc">Portfolio</div>
        </a>

        <a href="/messages" class="menu-item <%= typeof unreadMessages !== 'undefined' && unreadMessages > 0 ? 'messages-badge' : '' %>"
           data-count="<%= typeof unreadMessages !== 'undefined' ? unreadMessages : 0 %>">
            <div class="menu-icon" style="background: rgba(236, 72, 153, 0.12); color: #ec4899;">
                <i class="fas fa-envelope"></i>
            </div>
            <div class="menu-title">Messages</div>
            <div class="menu-desc">
                <%= typeof unreadMessages !== 'undefined' && unreadMessages > 0 ? unreadMessages + ' new inbox' : 'Inbox' %>
            </div>
        </a>

        <a href="/profile/settings" class="menu-item">
            <div class="menu-icon" style="background: rgba(249,115,22,0.12); color: #f97316;">
                <i class="fas fa-cog"></i>
            </div>
            <div class="menu-title">Settings</div>
            <div class="menu-desc">Preferences</div>
        </a>

        <% if (user.role === 'admin') { %>
        <a href="/admin" class="menu-item">
            <div class="menu-icon" style="background: rgba(239, 68, 68, 0.12); color: #ef4444;">
                <i class="fas fa-shield-alt"></i>
            </div>
            <div class="menu-title">Admin</div>
            <div class="menu-desc">Manage system</div>
        </a>
        <% } %>
    </div>

    <!-- Recent Trading Activity -->
    <div class="card">
        <h3 class="section-title">
            <i class="fas fa-list-alt"></i>
            Recent Trading Activity
        </h3>

        <% if (recentTrades && recentTrades.length > 0) { %>
            <div>
                <% recentTrades.forEach(trade => { %>
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--border);">
                        <div>
                            <div style="font-weight: 600; color: var(--text); font-size: 13px;">
                                <%= trade.direction.toUpperCase() %> <%= trade.pair_symbol %>
                                <% const plPositive = trade.profit_loss > 0; %>
                                <span class="pl-badge <%= plPositive ? 'pl-positive' : 'pl-negative' %>">
                                    <%= plPositive ? '+' : '' %>$<%= parseFloat(trade.profit_loss).toFixed(2) %>
                                </span>
                            </div>
                            <div style="font-size: 11px; color: var(--text-faint); margin-top: 3px;">
                                <%= new Date(trade.closed_at).toLocaleDateString() %> • <%= trade.lot_size %> lots @ <%= trade.leverage_used %>x
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <div class="pl-value" data-positive="<%= trade.profit_loss > 0 %>">
                                <%= trade.profit_loss > 0 ? '+' : '' %>$<%= Math.abs(parseFloat(trade.profit_loss)).toFixed(2) %>
                            </div>
                            <div style="font-size: 11px; color: var(--text-faint); margin-top: 3px;">
                                <%= trade.close_reason || 'Closed' %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div style="text-align: center; padding: 40px 0; color: var(--text-faint);">
                <i class="fas fa-history" style="font-size: 40px; margin-bottom: 14px; opacity: 0.3;"></i>
                <p>No trading activity yet</p>
                <a href="/trading" style="color: var(--accent); margin-top: 10px; display: inline-block; font-weight: 600;">Start Trading →</a>
            </div>
        <% } %>
    </div>

</div>

<!-- Bottom Nav (mobile) -->
<nav class="bottom-nav">
    <a href="/dashboard" class="nav-item active">
        <i class="fas fa-th-large"></i>
        Dashboard
    </a>
    <a href="/markets" class="nav-item">
        <i class="fas fa-signal"></i>
        Markets
    </a>
    <a href="/trading" class="nav-item">
        <i class="fas fa-arrow-right-arrow-left"></i>
        Trade
    </a>
    <a href="/investments" class="nav-item">
        <i class="fas fa-chart-pie"></i>
        Portfolio
    </a>
    <a href="/profile" class="nav-item">
        <i class="fas fa-user"></i>
        Account
    </a>
</nav>

<%- include('../partials/footer') %>

<script src="/socket.io/socket.io.js"></script>
<script>
    if (typeof io !== 'undefined') {
        const socket = io();

        socket.on('btcPrice', (data) => {
            if (!data || !data.price) return;

            const priceEl = document.getElementById('btcPrice');
            const changeEl = document.getElementById('btcChange');

            priceEl.textContent = '$' + data.price.toLocaleString();

            const pct = data.change24h ? data.change24h.toFixed(2) : '0.00';
            const isPositive = data.change24h >= 0;

            changeEl.className = 'ticker-change ' + (isPositive ? 'positive' : 'negative');
            changeEl.innerHTML = `<i class="fas fa-arrow-${isPositive ? 'up' : 'down'}"></i> ${Math.abs(pct)}%`;
        });
    }

    // Clear message from dashboard (visual only)
    function clearMessage(messageId) {
        const warningCard = document.getElementById(`warning-${messageId}`);
        if (warningCard) {
            warningCard.style.opacity = '0';
            warningCard.style.transform = 'translateX(20px)';
            warningCard.style.transition = 'all 0.3s ease';
            setTimeout(() => {
                warningCard.remove();
                checkNoWarnings();

                const cleared = JSON.parse(sessionStorage.getItem('clearedMessages') || '[]');
                cleared.push(messageId);
                sessionStorage.setItem('clearedMessages', JSON.stringify(cleared));
            }, 300);
        }
    }

    function checkNoWarnings() {
        const remaining = document.querySelectorAll('.warning-card');
        if (remaining.length === 0) {
            const alertsContainer = document.querySelector('.warning-alerts');
            if (alertsContainer) {
                alertsContainer.innerHTML = '<div class="no-warnings"><i class="fas fa-check-circle" style="color: #22c55e;"></i> No new messages</div>';
            }
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        const cleared = JSON.parse(sessionStorage.getItem('clearedMessages') || '[]');
        cleared.forEach(id => {
            const card = document.getElementById(`warning-${id}`);
            if (card) card.remove();
        });
        checkNoWarnings();
    });
</script>
