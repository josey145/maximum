<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div style="max-width: 400px; margin: 80px auto; padding: 0 16px;">
    <div style="text-align: center; color: white; background: #111118; padding: 40px; border-radius: 24px; border: 1px solid #1e1e2e; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        <div style="width: 70px; height: 70px; background: rgba(139, 92, 246, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
            <i class="fas fa-lock" style="font-size: 30px; color: #8b5cf6;"></i>
        </div>
        <h2 style="font-size: 24px; font-weight: 700; margin-bottom: 10px;">Security Verification</h2>
        <% if (messages.error && messages.error.length > 0) { %>
    <div style="background: rgba(239,68,68,0.1); border: 1px solid #ef4444; border-radius: 8px; padding: 12px; margin-bottom: 20px; color: #ef4444; font-size: 13px;">
        <%= messages.error[0] %>
            </div>
        <% } %>
        <% if (messages.success && messages.success.length > 0) { %>
            <div style="background: rgba(34,197,94,0.1); border: 1px solid #22c55e; border-radius: 8px; padding: 12px; margin-bottom: 20px; color: #22c55e; font-size: 13px;">
                <%= messages.success[0] %>
            </div>
        <% } %>
        <p style="color: #a1a1aa; font-size: 14px; margin-bottom: 30px;">Enter your 6-digit withdrawal code to proceed.</p>

        <form action="/transactions/withdraw/verify" method="POST">
            <input type="password" name="withdrawal_code" maxlength="6" required placeholder="••••••" 
       style="width: 100%; padding: 16px; background: #1c1c27; border: 1px solid #2d2d3f; border-radius: 12px; color: white; text-align: center; font-size: 28px; letter-spacing: 8px; outline: none; margin-bottom: 20px;">
            <button type="submit" style="width: 100%; padding: 16px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; border-radius: 12px; color: white; font-weight: 600; cursor: pointer;">Verify & Unlock</button>
        </form>

        <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #1e1e2e;">
            <p style="color: #52525b; font-size: 13px;">Need a code? <a href="/messages" style="color: #8b5cf6; text-decoration: none;">Contact Support</a></p>
        </div>
    </div>
</div>
<%- include('../partials/footer') %>