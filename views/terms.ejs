<%- include('partials/head') %>
<%- include('partials/navbar') %>

<section class="section" style="padding-top: 140px;">
    <div class="section-head" style="margin-bottom: 40px;">
        <span class="section-eyebrow">Legal</span>
        <h1 class="section-title" style="margin: 0 auto 10px; text-align: center;">Terms of Service</h1>
        <p class="section-subtitle mono" style="text-align: center; font-size: 13px;">Last updated: March 2024</p>
    </div>

    <div class="card legal-doc" style="max-width: 760px; margin: 0 auto;">

        <div class="legal-clause">
            <span class="legal-num">01</span>
            <div>
                <h3>Acceptance of Terms</h3>
                <p>By accessing or using <%= site.name %>'s services, you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our platform.</p>
            </div>
        </div>

        <div class="legal-clause">
            <span class="legal-num">02</span>
            <div>
                <h3>Eligibility</h3>
                <p>You must be at least 18 years old to use our services. By using <%= site.name %>, you represent and warrant that you meet all eligibility requirements.</p>
            </div>
        </div>

        <div class="legal-clause">
            <span class="legal-num">03</span>
            <div>
                <h3>Account Security</h3>
                <p>You are responsible for maintaining the confidentiality of your account credentials. Notify us immediately of any unauthorized use of your account.</p>
            </div>
        </div>

        <div class="legal-clause">
            <span class="legal-num">04</span>
            <div>
                <h3>Trading Risks</h3>
                <p>Cryptocurrency trading involves substantial risk. You acknowledge that you understand these risks and are solely responsible for your trading decisions.</p>
            </div>
        </div>

        <div class="legal-clause">
            <span class="legal-num">05</span>
            <div>
                <h3>Prohibited Activities</h3>
                <p>You agree not to engage in market manipulation, money laundering, or any illegal activities using our platform.</p>
            </div>
        </div>

        <div class="legal-clause">
            <span class="legal-num">06</span>
            <div>
                <h3>Limitation of Liability</h3>
                <p><%= site.name %> shall not be liable for any indirect, incidental, or consequential damages arising from your use of our services.</p>
            </div>
        </div>

        <div class="legal-clause" style="border-bottom: none;">
            <span class="legal-num">07</span>
            <div>
                <h3>Changes to Terms</h3>
                <p>We reserve the right to modify these terms at any time. Continued use of our services constitutes acceptance of updated terms.</p>
            </div>
        </div>

        <div style="margin-top: 12px; padding-top: 28px; border-top: 1px solid var(--edge); text-align: center;">
            <p style="color: var(--mist);">
                Questions? Contact us at
                <% if (site.support_email) { %>
                    <a href="mailto:<%= site.support_email %>" style="color: var(--signal); text-decoration: none; font-weight: 600;"><%= site.support_email %></a>
                <% } else { %>
                    our support team
                <% } %>
            </p>
        </div>
    </div>
</section>

<style>
    .legal-doc { padding: 40px; }
    .legal-clause {
        display: grid;
        grid-template-columns: 44px 1fr;
        gap: 18px;
        padding: 22px 0;
        border-bottom: 1px solid var(--edge);
    }
    .legal-clause:first-child { padding-top: 0; }
    .legal-num {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 12px;
        color: var(--signal);
        padding-top: 3px;
    }
    .legal-clause h3 {
        font-size: 15.5px;
        margin-bottom: 8px;
        font-family: 'Space Grotesk', sans-serif;
        color: var(--paper);
    }
    .legal-clause p {
        color: var(--mist);
        font-size: 14.5px;
        line-height: 1.75;
    }
    @media (max-width: 560px) {
        .legal-doc { padding: 26px 20px; }
        .legal-clause { grid-template-columns: 1fr; gap: 6px; }
    }
</style>

<%- include('partials/footer') %>
