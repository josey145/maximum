<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<style>
    .profile-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 24px 16px;
    }

    .profile-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 24px;
        padding: 32px;
        color: white;
        margin-bottom: 24px;
        text-align: center;
    }

    .profile-avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        margin: 0 auto 16px;
        border: 4px solid rgba(255,255,255,0.3);
    }

    .profile-name {
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .profile-email {
        opacity: 0.9;
        font-size: 14px;
    }

    .form-card {
        background: #111118;
        border: 1px solid #1e1e2e;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 16px;
    }

    .form-title {
        font-size: 18px;
        font-weight: 600;
        color: #f4f4f5;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-group {
        margin-bottom: 16px;
    }

    .form-label {
        display: block;
        font-size: 12px;
        color: #a1a1aa;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
    }

    .form-input {
        width: 100%;
        background: #0d0d14;
        border: 1px solid #1e1e2e;
        border-radius: 10px;
        padding: 12px 14px;
        color: #f4f4f5;
        font-size: 14px;
        transition: border-color 0.2s;
    }

    .form-input:focus {
        outline: none;
        border-color: #8b5cf6;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .btn-save {
        width: 100%;
        padding: 14px;
        background: #8b5cf6;
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-save:hover {
        background: #7c3aed;
        transform: translateY(-1px);
    }

    .kyc-status {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 500;
    }

    .kyc-pending {
        background: rgba(234,179,8,0.1);
        color: #facc15;
    }

    .kyc-verified {
        background: rgba(34,197,94,0.1);
        color: #22c55e;
    }

    @media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="profile-container">
    <div class="profile-header">
        <div class="profile-avatar">
            <i class="fas fa-user"></i>
        </div>
        <div class="profile-name"><%= user.username %></div>
        <div class="profile-email"><%= user.email %></div>
        <div style="margin-top: 16px;">
            <span class="kyc-status <%= user.kyc_status === 'verified' ? 'kyc-verified' : 'kyc-pending' %>">
                <i class="fas <%= user.kyc_status === 'verified' ? 'fa-check-circle' : 'fa-clock' %>"></i>
                <%= user.kyc_status.toUpperCase() %>
            </span>
        </div>
    </div>

    <form action="/profile/update" method="POST">
        <div class="form-card">
            <h3 class="form-title"><i class="fas fa-user-circle" style="color: #8b5cf6;"></i> Personal Information</h3>
            
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Username</label>
                    <input type="text" name="username" class="form-input" value="<%= user.username %>" readonly>
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-input" value="<%= user.email %>" readonly>
                </div>
                <!-- Add this before the Save button in profile.ejs -->
            <div class="form-group">
            <label class="form-label">Preferred Currency</label>
            <select name="currency" class="form-input">
                <option value="USD" <%= user.currency === 'USD' ? 'selected' : '' %>>USD ($) - US Dollar</option>
                <option value="EUR" <%= user.currency === 'EUR' ? 'selected' : '' %>>EUR (€) - Euro</option>
                <option value="GBP" <%= user.currency === 'GBP' ? 'selected' : '' %>>GBP (£) - British Pound</option>
                <option value="NGN" <%= user.currency === 'NGN' ? 'selected' : '' %>>NGN (₦) - Nigerian Naira</option>
                <option value="GHS" <%= user.currency === 'GHS' ? 'selected' : '' %>>GHS (₵) - Ghana Cedi</option>
                <option value="KES" <%= user.currency === 'KES' ? 'selected' : '' %>>KES (KSh) - Kenyan Shilling</option>
                <option value="ZAR" <%= user.currency === 'ZAR' ? 'selected' : '' %>>ZAR (R) - South African Rand</option>
                <option value="JPY" <%= user.currency === 'JPY' ? 'selected' : '' %>>JPY (¥) - Japanese Yen</option>
                <option value="BTC" <%= user.currency === 'BTC' ? 'selected' : '' %>>BTC (₿) - Bitcoin</option>
                <option value="ETH" <%= user.currency === 'ETH' ? 'selected' : '' %>>ETH (Ξ) - Ethereum</option>
            </select>
            <small style="color: #52525b; display: block; margin-top: 4px;">
                All balances will be displayed in this currency
            </small>
            </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Phone Number</label>
                    <input type="tel" name="phone" class="form-input" value="<%= user.phone || '' %>" placeholder="+1 234 567 8900">
                </div>
                <div class="form-group">
                    <label class="form-label">Date of Birth</label>
                    <input type="date" name="dob" class="form-input" value="<%= user.dob || '' %>">
                </div>
            </div>
        </div>

        <div class="form-card">
            <h3 class="form-title"><i class="fas fa-map-marker-alt" style="color: #22c55e;"></i> Address Information</h3>
            
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Country</label>
                    <input type="text" name="country" class="form-input" value="<%= user.country || '' %>">
                </div>
                <div class="form-group">
                    <label class="form-label">State/Region</label>
                    <input type="text" name="state" class="form-input" value="<%= user.state || '' %>">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">City</label>
                    <input type="text" name="city" class="form-input" value="<%= user.city || '' %>">
                </div>
                <div class="form-group">
                    <label class="form-label">ZIP/Postal Code</label>
                    <input type="text" name="zip" class="form-input" value="<%= user.zip || '' %>">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Street Address</label>
                <input type="text" name="address" class="form-input" value="<%= user.address || '' %>">
            </div>
        </div>

        <div class="form-card">
            <h3 class="form-title"><i class="fas fa-shield-alt" style="color: #f97316;"></i> Identity Verification</h3>
            
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">ID Type</label>
                    <input type="text" class="form-input" value="<%= user.id_type || 'Not submitted' %>" readonly>
                </div>
                <div class="form-group">
                    <label class="form-label">ID Number</label>
                    <input type="text" class="form-input" value="<%= user.id_number || 'Not submitted' %>" readonly>
                </div>
            </div>

            <% if (user.kyc_status !== 'verified') { %>
                <div style="background: rgba(234,179,8,0.1); border: 1px solid rgba(234,179,8,0.3); border-radius: 10px; padding: 16px; margin-top: 16px;">
                    <p style="color: #facc15; font-size: 14px; margin: 0;">
                        <i class="fas fa-info-circle"></i> Your KYC is pending verification. You'll be notified once approved.
                    </p>
                </div>
            <% } %>
        </div>

        <button type="submit" class="btn-save">
            <i class="fas fa-save"></i> Save Changes
        </button>
    </form>
</div>

<%- include('../partials/footer') %>