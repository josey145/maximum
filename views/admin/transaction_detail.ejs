<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dashboard">
    <div class="dashboard-header" style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px;">
        <a href="/admin/withdrawals" class="btn btn-outline">
            <i class="fas fa-arrow-left"></i> Back
        </a>
        <div>
            <h1 class="dashboard-title">Transaction #<%= transaction.id %></h1>
            <p style="color: var(--text-secondary);">
                <%= transaction.type.toUpperCase() %> · 
                <%= new Date(transaction.created_at).toLocaleString() %>
            </p>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">

        <!-- Transaction Info -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-receipt"></i> Transaction Details</h3>
            </div>
            <div style="padding: 20px;">

                <div style="text-align: center; margin-bottom: 24px;">
                    <div style="font-size: 48px; font-weight: 800; 
                        color: <%= transaction.type === 'deposit' ? '#22c55e' : '#ef4444' %>;">
                        <%= transaction.type === 'deposit' ? '+' : '-' %>$<%= parseFloat(transaction.amount).toFixed(2) %>
                    </div>
                    <div style="margin-top: 8px;">
                        <% if (transaction.status === 'pending') { %>
                            <span class="status-badge" style="background: rgba(245,158,11,0.2); color: #f59e0b; padding: 6px 16px; border-radius: 20px; font-weight: 600;">
                                ⏳ PENDING
                            </span>
                        <% } else if (transaction.status === 'approved' || transaction.status === 'completed') { %>
                            <span class="status-badge" style="background: rgba(34,197,94,0.2); color: #22c55e; padding: 6px 16px; border-radius: 20px; font-weight: 600;">
                                ✓ <%= transaction.status.toUpperCase() %>
                            </span>
                        <% } else { %>
                            <span class="status-badge" style="background: rgba(239,68,68,0.2); color: #ef4444; padding: 6px 16px; border-radius: 20px; font-weight: 600;">
                                ✗ REJECTED
                            </span>
                        <% } %>
                    </div>
                </div>

                <table style="width: 100%; border-collapse: collapse;">
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Transaction ID</td>
                        <td style="padding: 12px 0; font-weight: 600; text-align: right;">#<%= transaction.id %></td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Type</td>
                        <td style="padding: 12px 0; font-weight: 600; text-align: right; text-transform: capitalize;"><%= transaction.type %></td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Payment Method</td>
                        <td style="padding: 12px 0; font-weight: 600; text-align: right; text-transform: capitalize;"><%= transaction.payment_method || 'N/A' %></td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Wallet / Address</td>
                        <td style="padding: 12px 0; font-weight: 600; text-align: right; word-break: break-all; max-width: 200px;"><%= transaction.external_id || 'N/A' %></td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Created</td>
                        <td style="padding: 12px 0; font-weight: 600; text-align: right;"><%= new Date(transaction.created_at).toLocaleString() %></td>
                    </tr>
                    <% if (transaction.approved_at) { %>
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Processed</td>
                        <td style="padding: 12px 0; font-weight: 600; text-align: right;"><%= new Date(transaction.approved_at).toLocaleString() %></td>
                    </tr>
                    <% } %>
                    <% if (transaction.approved_by_username) { %>
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Processed By</td>
                        <td style="padding: 12px 0; font-weight: 600; text-align: right;"><%= transaction.approved_by_username %></td>
                    </tr>
                    <% } %>
                    <% if (transaction.rejection_reason) { %>
                    <tr>
                        <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Rejection Reason</td>
                        <td style="padding: 12px 0; font-weight: 600; text-align: right; color: #ef4444;"><%= transaction.rejection_reason %></td>
                    </tr>
                    <% } %>
                </table>

                <!-- Action buttons if still pending -->
                <% if (transaction.status === 'pending') { %>
                <div style="display: flex; gap: 12px; margin-top: 24px;">
                    <form action="/admin/<%= transaction.type === 'deposit' ? 'deposits' : 'withdrawals' %>/approve/<%= transaction.id %>" method="POST" style="flex: 1;">
                        <button type="submit" class="btn btn-success" style="width: 100%;"
                            onclick="return confirm('Approve this transaction?')">
                            <i class="fas fa-check"></i> Approve
                        </button>
                    </form>
                    <form action="/admin/<%= transaction.type === 'deposit' ? 'deposits' : 'withdrawals' %>/reject/<%= transaction.id %>" method="POST" style="flex: 1;">
                        <input type="hidden" name="reason" value="Rejected by admin">
                        <button type="submit" class="btn btn-danger" style="width: 100%;"
                            onclick="return confirm('Reject this transaction?')">
                            <i class="fas fa-times"></i> Reject
                        </button>
                    </form>
                </div>
                <% } %>
            </div>
        </div>

        <!-- User Info -->
        <div>
            <div class="card" style="margin-bottom: 24px;">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-user"></i> User Details</h3>
                </div>
                <div style="padding: 20px;">
                    <table style="width: 100%; border-collapse: collapse;">
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Username</td>
                            <td style="padding: 12px 0; font-weight: 600; text-align: right;"><%= transaction.username %></td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Email</td>
                            <td style="padding: 12px 0; font-weight: 600; text-align: right;"><%= transaction.email %></td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Current Balance</td>
                            <td style="padding: 12px 0; font-weight: 600; text-align: right; color: #22c55e;">$<%= parseFloat(transaction.current_balance || 0).toFixed(2) %></td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Phone</td>
                            <td style="padding: 12px 0; font-weight: 600; text-align: right;"><%= transaction.phone || 'N/A' %></td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Country</td>
                            <td style="padding: 12px 0; font-weight: 600; text-align: right;"><%= transaction.country || 'N/A' %></td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">KYC Status</td>
                            <td style="padding: 12px 0; text-align: right;">
                                <span style="color: <%= transaction.kyc_status === 'approved' ? '#22c55e' : '#f59e0b' %>; font-weight: 600; text-transform: capitalize;">
                                    <%= transaction.kyc_status || 'pending' %>
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 12px 0; color: var(--text-secondary); font-size: 13px;">Account Verified</td>
                            <td style="padding: 12px 0; text-align: right;">
                                <span style="color: <%= transaction.account_verified ? '#22c55e' : '#ef4444' %>; font-weight: 600;">
                                    <%= transaction.account_verified ? '✓ Yes' : '✗ No' %>
                                </span>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- Recent Transaction History -->
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-history"></i> Recent Transactions</h3>
                </div>
                <div style="overflow-x: auto;">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% userHistory.forEach(h => { %>
                            <tr style="<%= h.id === transaction.id ? 'background: rgba(139,92,246,0.1);' : '' %>">
                                <td style="text-transform: capitalize;"><%= h.type %></td>
                                <td style="color: <%= h.type === 'deposit' ? '#22c55e' : '#ef4444' %>; font-weight: 600;">
                                    <%= h.type === 'deposit' ? '+' : '-' %>$<%= parseFloat(h.amount).toFixed(2) %>
                                </td>
                                <td>
                                    <span style="font-size: 11px; font-weight: 600; text-transform: uppercase;
                                        color: <%= h.status === 'completed' || h.status === 'approved' ? '#22c55e' : h.status === 'pending' ? '#f59e0b' : '#ef4444' %>;">
                                        <%= h.status %>
                                    </span>
                                </td>
                                <td style="font-size: 12px; color: var(--text-secondary);">
                                    <%= new Date(h.created_at).toLocaleDateString() %>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>