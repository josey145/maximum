<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dashboard">
    <div class="dashboard-header">
        <h1 class="dashboard-title">Admin Panel</h1>
        <p style="color: var(--text-secondary);">Manage users and system settings</p>
    </div>

    <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> <%= success_msg %>
        </div>
    <% } %>

    <% if (error_msg && error_msg.length > 0) { %>
        <div class="alert alert-error">
            <i class="fas fa-exclamation-circle"></i> <%= error_msg %>
        </div>
    <% } %>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Total Users</div>
            <div class="stat-value"><%= users.length %></div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Admin Users</div>
            <div class="stat-value"><%= users.filter(u => u.role === 'admin').length %></div>
        </div>
        <div class="stat-card">
            <div class="stat-label">New Today</div>
            <div class="stat-value">0</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">System Status</div>
            <div class="stat-value" style="color: var(--success); font-size: 18px;">
                <i class="fas fa-check-circle"></i> Online
            </div>
        </div>
    </div>

    <div class="card">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h3 style="font-size: 20px; font-weight: 600;">User Management</h3>
            <button class="btn btn-primary btn-sm" onclick="alert('Add user feature coming soon')">
                <i class="fas fa-plus"></i> Add User
            </button>
        </div>

        <div style="overflow-x: auto;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                        <tr>
                            <td>#<%= user.id %></td>
                            <td>
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <div class="avatar" style="width: 32px; height: 32px; margin: 0; font-size: 12px;">
                                        <%= user.username.charAt(0).toUpperCase() %>
                                    </div>
                                    <%= user.username %>
                                </div>
                            </td>
                            <td><%= user.email %></td>
                            <td>
                                <span class="role-badge role-<%= user.role %>">
                                    <%= user.role %>
                                </span>
                            </td>
                            <td><%= new Date(user.created_at).toLocaleDateString() %></td>
                            <td>
                                <div class="action-btns">
                                    <form action="/admin/role/<%= user.id %>" method="POST" style="display: inline;">
                                        <input type="hidden" name="role" value="<%= user.role === 'admin' ? 'user' : 'admin' %>">
                                        <button type="submit" class="btn btn-outline btn-sm" onclick="return confirm('Change role for <%= user.username %>?')">
                                            <i class="fas fa-user-shield"></i>
                                        </button>
                                    </form>
                                    <% if (user.id !== currentUser.id) { %>
                                        <form action="/admin/delete/<%= user.id %>" method="POST" style="display: inline;">
                                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete <%= user.username %>? This cannot be undone.')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card" style="margin-top: 24px;">
        <h3 style="font-size: 20px; font-weight: 600; margin-bottom: 16px;">System Logs</h3>
        <div style="background: var(--secondary-bg); border-radius: 12px; padding: 16px; font-family: monospace; font-size: 13px; color: var(--text-secondary); max-height: 200px; overflow-y: auto;">
            <div style="margin-bottom: 8px;">[<%= new Date().toLocaleTimeString() %>] System initialized</div>
            <div style="margin-bottom: 8px;">[<%= new Date().toLocaleTimeString() %>] Telegram bot connected</div>
            <div style="margin-bottom: 8px;">[<%= new Date().toLocaleTimeString() %>] Price feed active (15s interval)</div>
            <div style="margin-bottom: 8px; color: var(--success);">[<%= new Date().toLocaleTimeString() %>] All systems operational</div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>