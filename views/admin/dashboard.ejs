            </div>
            <div style="display: flex; gap: 12px;">
                <button type="button" class="btn btn-outline" style="flex: 1;" onclick="closeModal('fundModal')">Cancel</button>
                <button type="submit" class="btn btn-success" style="flex: 1;">
                    <i class="fas fa-check"></i> Confirm Credit
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Deduct Modal -->
<div id="deductModal" class="modal">
    <div class="modal-content">
        <h3 style="margin-bottom: 20px; color: var(--danger);"><i class="fas fa-minus-circle"></i> Deduct From Account</h3>
        <p id="deductUserInfo" style="color: var(--text-secondary); margin-bottom: 20px;"></p>
        <form id="deductForm" method="POST">
            <div class="form-group">
                <label class="form-label">Amount (USDT)</label>
                <input type="number" name="amount" class="form-input" placeholder="100" min="0.01" step="0.01" required>
            </div>
            <div class="form-group">
                <label class="form-label">Reason (Required)</label>
                <input type="text" name="reason" class="form-input" placeholder="Fee, penalty, etc." required>
            </div>
            <div style="display: flex; gap: 12px;">
                <button type="button" class="btn btn-outline" style="flex: 1;" onclick="closeModal('deductModal')">Cancel</button>
                <button type="submit" class="btn btn-danger" style="flex: 1;">
                    <i class="fas fa-minus"></i> Confirm Deduction
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Withdraw Code Modal -->
<div id="withdrawCodeModal" class="modal">
    <div class="modal-content" style="text-align: center;">
        <div style="width: 80px; height: 80px; background: linear-gradient(135deg, var(--info), var(--purple)); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
            <i class="fas fa-key" style="font-size: 32px; color: white;"></i>
        </div>
        <h3 style="margin-bottom: 12px;">Withdrawal Code</h3>
        <p id="withdrawUserInfo" style="color: var(--text-secondary); margin-bottom: 24px;"></p>
        
        <div id="codeDisplaySection" style="display: none;">
            <div class="code-display" id="codeValue"></div>
            <div style="font-size: 12px; color: var(--warning); margin-bottom: 24px;">
                <i class="fas fa-clock"></i> Valid for 24 hours
            </div>
        </div>
        
        <form id="withdrawForm" method="POST" style="display: none;">
            <button type="submit" style="display: none;"></button>
        </form>
        
        <div style="display: flex; gap: 12px;">
            <button type="button" class="btn btn-outline" style="flex: 1;" onclick="closeModal('withdrawCodeModal')">Close</button>
            <button type="button" id="generateCodeBtn" class="btn btn-primary" style="flex: 1;" onclick="submitWithdrawCode()">
                <i class="fas fa-magic"></i> Generate
            </button>
        </div>
    </div>
</div>

<script>
// Tab switching
function switchTab(tabName) {
    document.querySelectorAll('.tab').forEach(tab => tab.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
    event.target.classList.add('active');
    document.getElementById(tabName).classList.add('active');
    window.location.hash = tabName;
}

// Modal functions
function openModal(modalId) {
    document.getElementById(modalId).classList.add('active');
    document.body.style.overflow = 'hidden';
}

function closeModal(modalId) {
    document.getElementById(modalId).classList.remove('active');
    document.body.style.overflow = '';
    if (modalId === 'withdrawCodeModal') {
        document.getElementById('codeDisplaySection').style.display = 'none';
        document.getElementById('generateCodeBtn').style.display = 'block';
    }
}

document.querySelectorAll('.modal').forEach(modal => {
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(modal.id); });
});

// Search users
function searchUsers() {
    const input = document.getElementById('userSearch');
    const filter = input.value.toLowerCase();
    const tr = document.querySelectorAll('#usersTable tbody tr');
    tr.forEach(row => {
        const username = row.getAttribute('data-username');
        const email = row.getAttribute('data-email');
        const id = row.getAttribute('data-id');
        row.style.display = (username.includes(filter) || email.includes(filter) || id.includes(filter)) ? '' : 'none';
    });
}

// Dropdown toggle
function toggleDropdown(menuId) {
    const menu = document.getElementById(menuId);
    const isActive = menu.classList.contains('active');
    document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.remove('active'));
    if (!isActive) menu.classList.add('active');
}

document.addEventListener('click', (e) => {
    if (!e.target.closest('.action-btns')) {
        document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.remove('active'));
    }
});

// Modals
function openFundModal(userId, username) {
    document.getElementById('fundUserInfo').textContent = `Credit funds to ${username}`;
    document.getElementById('fundForm').action = `/admin/fund/${userId}`;
    openModal('fundModal');
}

function openDeductModal(userId, username) {
    document.getElementById('deductUserInfo').textContent = `Deduct funds from ${username}`;
    document.getElementById('deductForm').action = `/admin/deduct/${userId}`;
    openModal('deductModal');
}

// Withdraw code
let currentWithdrawUserId = null;
function generateWithdrawCode(userId, username) {
    currentWithdrawUserId = userId;
    document.getElementById('withdrawUserInfo').textContent = `Generate code for ${username}`;
    document.getElementById('withdrawForm').action = `/admin/generate-withdraw-code/${userId}`;
    openModal('withdrawCodeModal');
}

function submitWithdrawCode() {
    const form = document.getElementById('withdrawForm');
    const btn = document.getElementById('generateCodeBtn');
    
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generating...';
    btn.disabled = true;
    
    fetch(form.action, {
        method: 'POST',
        headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            document.getElementById('codeValue').textContent = data.code;
            document.getElementById('codeDisplaySection').style.display = 'block';
            btn.style.display = 'none';
        } else {
            alert('Error: ' + data.error);
            btn.innerHTML = '<i class="fas fa-magic"></i> Generate';
            btn.disabled = false;
        }
    })
    .catch(() => form.submit());
}

// Load hash
window.addEventListener('load', () => {
    const hash = window.location.hash.replace('#', '');
    if (hash && document.getElementById(hash)) {
        const btn = document.querySelector(`button[onclick="switchTab('${hash}')"]`);
        if (btn) btn.click();
    }
});
</script>

<%- include('../partials/footer') %>