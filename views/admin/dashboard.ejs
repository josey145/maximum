    <div class="modal-content">
        <h3 style="margin-bottom: 20px;"><i class="fas fa-broadcast-tower" style="color: var(--primary);"></i> Create Trading Signal</h3>
        
        <% if (!signalBotConfigured) { %>
            <div class="alert alert-warning" style="margin-bottom: 16px;">
                <i class="fas fa-exclamation-triangle"></i> Signal bot not configured. Signal will be saved but not broadcast.
            </div>
        <% } %>
        
        <form action="/admin/signal/create" method="POST">
            <div class="form-group">
                <label class="form-label">Trading Pair</label>
                <select name="pair" class="form-select" required>
                    <option value="EURUSD">EUR/USD</option>
                    <option value="GBPUSD">GBP/USD</option>
                    <option value="USDJPY">USD/JPY</option>
                    <option value="XAUUSD">GOLD (XAU/USD)</option>
                    <option value="XAGUSD">SILVER (XAG/USD)</option>
                    <option value="BTCUSD">BTC/USD</option>
                    <option value="ETHUSD">ETH/USD</option>
                </select>
            </div>
            
            <div class="form-group">
                <label class="form-label">Direction</label>
                <select name="direction" class="form-select" required>
                    <option value="buy">📈 BUY (Long)</option>
                    <option value="sell">📉 SELL (Short)</option>
                </select>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div class="form-group">
                    <label class="form-label">Entry Price</label>
                    <input type="number" name="entryPrice" class="form-input" step="0.00001" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Target Price</label>
                    <input type="number" name="targetPrice" class="form-input" step="0.00001" required>
                </div>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div class="form-group">
                    <label class="form-label">Stop Loss</label>
                    <input type="number" name="stopLoss" class="form-input" step="0.00001" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Leverage</label>
                    <select name="leverage" class="form-select">
