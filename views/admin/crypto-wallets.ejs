<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<script src="https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js"></script>

<style>
.wallet-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 20px;
    align-items: center;
}

.wallet-active { border-left: 4px solid var(--success); }
.wallet-inactive { border-left: 4px solid var(--danger); opacity: 0.7; }

.crypto-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 24px;
    border-left: 4px solid #f59e0b;
}

.crypto-inactive {
    border-left-color: var(--danger);
    opacity: 0.6;
}

.status-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
}

.method-badge {
    background: var(--secondary-bg);
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 12px;
}

.crypto-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
}

.crypto-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(135deg, #f59e0b, #d97706);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 700;
    color: white;
}

.crypto-title {
    flex: 1;
}

.crypto-actions {
    display: flex;
    gap: 8px;
}

.wallet-table {
    width: 100%;
    border-collapse: collapse;
}

.wallet-table th {
    text-align: left;
    padding: 12px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border);
}

.wallet-table td {
    padding: 16px 12px;
    border-bottom: 1px solid var(--border);
}

.wallet-table tr:last-child td {
    border-bottom: none;
}

.address-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--text-secondary);
    background: var(--secondary-bg);
    padding: 6px 12px;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.empty-state {
    text-align: center;
    padding: 40px;
    color: var(--text-secondary);
}

.empty-state i {
    font-size: 48px;
    opacity: 0.3;
    margin-bottom: 16px;
}

.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 20px;
}

.modal-overlay.active {
    display: flex;
}

.modal-content {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    width: 100%;
    max-width: 600px;
    max-height: 90vh;
    overflow: hidden;
    animation: modalSlide 0.3s ease;
}

@keyframes modalSlide {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
}

.modal-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.modal-body {
    padding: 24px;
    overflow-y: auto;
    max-height: calc(90vh - 140px);
}

.modal-footer {
    padding: 16px 24px;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 12px;
    justify-content: flex-end;
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
}

.form-group input,
.form-group select,
.form-group textarea {
    width: 100%;
    padding: 12px 16px;
    background: var(--secondary-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-size: 14px;
    transition: border-color 0.2s;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
    outline: none;
    border-color: var(--primary);
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}

.checkbox-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
}

.checkbox-wrapper input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: var(--primary);
}

.stats-grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 24px;
}

@media (max-width: 1024px) {
    .stats-grid-4 {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 640px) {
    .stats-grid-4 {
        grid-template-columns: 1fr;
    }
    
    .wallet-card {
        grid-template-columns: 1fr;
    }
    
    .crypto-header {
        flex-wrap: wrap;
    }
}
</style>

<div class="dashboard">
    <div class="dashboard-header">
        <h1 class="dashboard-title">Crypto Wallet Management</h1>
        <p style="color: var(--text-secondary);">Manage deposit addresses for crypto payments</p>
    </div>

    <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success_msg %></div>
    <% } %>

    <% if (error_msg && error_msg.length > 0) { %>
        <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error_msg %></div>
    <% } %>

    <% if (typeof warning_msg !== 'undefined' && warning_msg && warning_msg.length > 0) { %>
        <div class="alert alert-warning"><i class="fas fa-exclamation-triangle"></i> <%= warning_msg %></div>
    <% } %>

    <!-- Stats -->
    <div class="stats-grid-4">
        <div class="stat-card">
            <div class="stat-label">Total Cryptocurrencies</div>
            <div class="stat-value" style="color: #f59e0b;">
                <%= Object.keys(walletsByCrypto).length %>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Active Addresses</div>
            <div class="stat-value" style="color: var(--success);">
                <%= Object.values(walletsByCrypto).flat().filter(w => w.is_active).length %>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Inactive Addresses</div>
            <div class="stat-value" style="color: var(--danger);">
                <%= Object.values(walletsByCrypto).flat().filter(w => !w.is_active).length %>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Total Deposits</div>
            <div class="stat-value" style="color: #3b82f6;">
                <%= depositStats.reduce((acc, s) => acc + parseInt(s.total_deposits), 0) %>
            </div>
        </div>
    </div>

    <!-- Action Bar -->
    <div class="card" style="margin-bottom: 24px;">
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <button class="btn btn-primary" onclick="openAddModal()">
                <i class="fas fa-plus"></i> Add Wallet Address
            </button>
        </div>
    </div>

    

    <!-- Crypto Wallets List -->
    <% Object.entries(walletsByCrypto).forEach(([symbol, wallets]) => { %>
        <% const hasActive = wallets.some(w => w.is_active); %>
        <div class="crypto-card <%= !hasActive ? 'crypto-inactive' : '' %>">
            <div class="crypto-header">
                <div class="crypto-icon">
                    <%= symbol.substring(0, 2) %>
                </div>
                <div class="crypto-title">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 4px;">
                        <h3 style="margin: 0; font-size: 18px; font-weight: 600;"><%= symbol %></h3>
                        <span class="method-badge"><%= wallets.length %> address<%= wallets.length > 1 ? 'es' : '' %></span>
                        <% const stat = depositStats.find(s => s.crypto_type === symbol); %>
                        <% if (stat) { %>
                            <span class="method-badge" style="background: rgba(16, 185, 129, 0.2); color: #10b981;">
                                <%= stat.total_deposits %> deposits
                            </span>
                        <% } %>
                    </div>
                    <p style="margin: 0; color: var(--text-secondary); font-size: 13px;">
                        <%= wallets.filter(w => w.is_active).length %> active
                        <% if (stat) { %>• $<%= parseFloat(stat.total_received).toFixed(2) %> received<% } %>
                    </p>
                </div>
                <div class="crypto-actions">
                    <button class="btn btn-primary btn-sm" onclick="openAddModal('<%= symbol %>')">
                        <i class="fas fa-plus"></i> Add <%= symbol %> Address
                    </button>
                </div>
            </div>

            <!-- Wallets Table -->
            <table class="wallet-table">
                <thead>
                    <tr>
                        <th>Address</th>
                        <th>Network</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% wallets.forEach(wallet => { %>
                        <tr>
                            <td>
                                <div class="address-text">
                                    <%= wallet.address.substring(0, 20) %>...<%= wallet.address.slice(-8) %>
                                    <button onclick="copyToClipboard('<%= wallet.address %>')" class="btn btn-outline btn-sm" style="padding: 4px 8px;" title="Copy Address">
                                        <i class="fas fa-copy"></i>
                                    </button>
                                </div>
                                <% if (wallet.qr_code) { %>
                                    <div style="font-size: 11px; color: var(--text-secondary); margin-top: 4px;">
                                        <i class="fas fa-qrcode"></i> QR Code available
                                    </div>
                                <% } %>
                            </td>
                            <td>
                                <span class="method-badge"><%= wallet.network || 'Mainnet' %></span>
                            </td>
                            <td>
                                <% if (wallet.is_active) { %>
                                    <span class="status-badge" style="background: rgba(16, 185, 129, 0.2); color: #10b981;">Active</span>
                                <% } else { %>
                                    <span class="status-badge" style="background: rgba(239, 68, 68, 0.2); color: #ef4444;">Inactive</span>
                                <% } %>
                            </td>
                            <td>
                                <div style="display: flex; gap: 6px;">
                                    <button onclick="editWallet(<%= JSON.stringify(wallet) %>)" class="btn btn-outline btn-sm" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <form method="POST" action="/admin/crypto-wallets/<%= wallet.id %>/toggle" style="display: inline;">
                                        <button type="submit" class="btn <%= wallet.is_active ? 'btn-danger' : 'btn-success' %> btn-sm" title="<%= wallet.is_active ? 'Deactivate' : 'Activate' %>">
                                            <i class="fas <%= wallet.is_active ? 'fa-pause' : 'fa-play' %>"></i>
                                        </button>
                                    </form>
                                    <form method="POST" action="/admin/crypto-wallets/<%= wallet.id %>/delete" style="display: inline;" onsubmit="return confirm('Delete this wallet address?');">
                                        <button type="submit" class="btn btn-danger btn-sm" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% }); %>

    <% if (Object.keys(walletsByCrypto).length === 0) { %>
        <div class="card">
            <div class="empty-state">
                <i class="fas fa-wallet" style="color: #f59e0b;"></i>
                <h3 style="margin: 0 0 8px; font-size: 18px;">No Wallet Addresses</h3>
                <p>No crypto payment addresses configured yet.</p>
                <button onclick="openAddModal()" class="btn btn-primary" style="margin-top: 16px;">
                    <i class="fas fa-plus"></i> Add First Wallet
                </button>
            </div>
        </div>
    <% } %>
</div>

<!-- Add Wallet Modal -->
<div id="addModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-header">
            <h3 style="margin: 0; font-size: 18px; font-weight: 600;">
                <i class="fas fa-plus" style="color: #f59e0b; margin-right: 8px;"></i> 
                Add Wallet Address
            </h3>
            <button onclick="closeAddModal()" class="btn btn-outline btn-sm"><i class="fas fa-times"></i></button>
        </div>
        <form method="POST" action="/admin/crypto-wallets/add">
            <div class="modal-body">
                <div class="form-group">
                    <label>Cryptocurrency Symbol</label>
                    <input type="text" name="symbol" id="addSymbol" required placeholder="e.g., BTC, ETH, USDT" style="text-transform: uppercase;">
                    <small style="color: var(--text-secondary); font-size: 12px;">Enter the symbol (BTC, ETH, USDT, etc.)</small>
                </div>
                <div class="form-group">
                    <label>Wallet Address</label>
                    <input type="text" name="address" required placeholder="Enter wallet address">
                </div>
                <div class="form-group">
                    <label>Network</label>
                    <input type="text" name="network" placeholder="e.g., ERC20, TRC20, BEP20, Mainnet" value="Mainnet">
                </div>
                <div class="form-group">
                    <label>QR Code URL (optional)</label>
                    <input type="text" name="qr_code" placeholder="https://... or data:image...">
                    <small style="color: var(--text-secondary); font-size: 12px;">URL to QR code image or base64 data</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" onclick="closeAddModal()">Cancel</button>
                <button type="submit" class="btn btn-primary">Add Wallet</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Wallet Modal -->
<div id="editModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-header">
            <h3 style="margin: 0; font-size: 18px; font-weight: 600;">
                <i class="fas fa-edit" style="color: #f59e0b; margin-right: 8px;"></i> 
                Edit Wallet Address
            </h3>
            <button onclick="closeEditModal()" class="btn btn-outline btn-sm"><i class="fas fa-times"></i></button>
        </div>
        <form method="POST" id="editForm" action="">
            <div class="modal-body">
                <div class="form-group">
                    <label>Cryptocurrency Symbol</label>
                    <input type="text" id="editSymbol" readonly style="background: var(--secondary-bg); opacity: 0.7; text-transform: uppercase;">
                </div>
                <div class="form-group">
                    <label>Wallet Address</label>
                    <input type="text" name="address" id="editAddress" required>
                </div>
                <div class="form-group">
                    <label>Network</label>
                    <input type="text" name="network" id="editNetwork">
                </div>
                <div class="form-group">
                    <label>QR Code URL (optional)</label>
                    <input type="text" name="qr_code" id="editQrCode">
                </div>
                <div class="form-group">
                    <label class="checkbox-wrapper">
                        <input type="checkbox" name="is_active" id="editIsActive" value="1">
                        <span>Active (available for deposits)</span>
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" onclick="closeEditModal()">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
function openAddModal(symbol = '') {
    document.getElementById('addModal').classList.add('active');
    if (symbol) {
        document.getElementById('addSymbol').value = symbol;
    }
}

function closeAddModal() {
    document.getElementById('addModal').classList.remove('active');
    document.getElementById('addSymbol').value = '';
}

function editWallet(wallet) {
    document.getElementById('editForm').action = `/admin/crypto-wallets/${wallet.id}/update`;
    document.getElementById('editSymbol').value = wallet.symbol;
    document.getElementById('editAddress').value = wallet.address;
    document.getElementById('editNetwork').value = wallet.network || 'Mainnet';
    document.getElementById('editQrCode').value = wallet.qr_code || '';
    document.getElementById('editIsActive').checked = wallet.is_active;
    
    document.getElementById('editModal').classList.add('active');
}

function closeEditModal() {
    document.getElementById('editModal').classList.remove('active');
}

function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
        const toast = document.createElement('div');
        toast.className = 'alert alert-success';
        toast.style.cssText = 'position: fixed; bottom: 20px; right: 20px; z-index: 9999; animation: slideIn 0.3s ease;';
        toast.innerHTML = '<i class="fas fa-check-circle"></i> Address copied to clipboard';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    });
}

// Close modals on outside click
document.querySelectorAll('.modal-overlay').forEach(modal => {
    modal.addEventListener('click', function(e) {
        if (e.target === this) {
            this.classList.remove('active');
        }
    });
});

// Add slideIn animation
const style = document.createElement('style');
style.textContent = `
    @keyframes slideIn {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }
`;
document.head.appendChild(style);
</script>

<%- include('../partials/footer') %>