<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<style>
.withdrawal-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 20px;
    align-items: center;
}

.withdrawal-pending { border-left: 4px solid var(--warning); }
.withdrawal-approved { border-left: 4px solid var(--success); }
.withdrawal-rejected { border-left: 4px solid var(--danger); }

.status-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
}

.amount-display {
    font-size: 24px;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
}

.method-badge {
    background: var(--secondary-bg);
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 12px;
}
</style>

<div class="dashboard">
    <div class="dashboard-header">
        <h1 class="dashboard-title">Withdrawal Management</h1>
        <p style="color: var(--text-secondary);">Review and process user withdrawal requests</p>
    </div>

    <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success_msg %></div>
    <% } %>

    <% if (error_msg && error_msg.length > 0) { %>
        <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error_msg %></div>
    <% } %>

    <!-- Stats -->
    <div class="stats-grid" style="grid-template-columns: repeat(4, 1fr); margin-bottom: 24px;">
        <div class="stat-card">
            <div class="stat-label">Pending</div>
            <div class="stat-value" style="color: var(--warning);">
                <%= withdrawals.filter(w => w.status === 'pending').length %>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Approved Today</div>
            <div class="stat-value" style="color: var(--success);">
                <%= withdrawals.filter(w => w.status === 'approved' && new Date(w.approved_at).toDateString() === new Date().toDateString()).length %>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Total Amount (Pending)</div>
            <div class="stat-value" style="color: var(--info);">
                $<%= withdrawals.filter(w => w.status === 'pending').reduce((sum, w) => sum + parseFloat(w.amount), 0).toFixed(2) %>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Total Processed</div>
            <div class="stat-value">
                $<%= withdrawals.filter(w => w.status === 'approved').reduce((sum, w) => sum + parseFloat(w.amount), 0).toFixed(2) %>
            </div>
        </div>
    </div>

    <!-- Pending Withdrawals Section -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title"><i class="fas fa-clock" style="color: var(--warning);"></i> Pending Approvals</h3>
        </div>

        <% const pending = withdrawals.filter(w => w.status === 'pending'); %>
        <% if (pending.length > 0) { %>
            <% pending.forEach(w => { %>
                <div class="withdrawal-card withdrawal-pending">
                    <div>
                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                            <span class="amount-display">$<%= parseFloat(w.amount).toFixed(2) %></span>
                            <span class="status-badge" style="background: rgba(245, 158, 11, 0.2); color: var(--warning);">
                                Pending
                            </span>
                            <span class="method-badge"><%= w.payment_method %></span>
                        </div>
                        <div style="color: var(--text-secondary); font-size: 14px;">
                            <i class="fas fa-user"></i> <%= w.username %> (<%= w.email %>)
                            <span style="margin: 0 8px;">•</span>
                            <i class="fas fa-wallet"></i> <%= w.external_id %>
                            <span style="margin: 0 8px;">•</span>
                            <i class="fas fa-clock"></i> <%= new Date(w.created_at).toLocaleString() %>
                        </div>
                    </div>
                    <div style="display: flex; gap: 8px;">
                        <button class="btn btn-success" onclick="openApproveModal('<%= w.id %>', '<%= w.username %>', '<%= w.amount %>')">
                            <i class="fas fa-check"></i> Approve
                        </button>
                        <button class="btn btn-danger" onclick="openRejectModal('<%= w.id %>', '<%= w.username %>', '<%= w.amount %>')">
                            <i class="fas fa-times"></i> Reject
                        </button>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div style="text-align: center; padding: 40px; color: var(--text-secondary);">
                <i class="fas fa-check-circle" style="font-size: 48px; opacity: 0.3; margin-bottom: 16px;"></i>
                <p>No pending withdrawals</p>
            </div>
        <% } %>
    </div>

    <!-- Recent History -->
    <div class="card" style="margin-top: 24px;">
        <div class="card-header">
            <h3 class="card-title">Recent History</h3>
        </div>
        <div style="overflow-x: auto;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Amount</th>
                        <th>Method</th>
                        <th>Status</th>
                        <th>Processed</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% withdrawals.filter(w => w.status !== 'pending').slice(0, 10).forEach(w => { %>
                        <tr>
                            <td><%= w.username %></td>
                            <td class="balance-display">$<%= parseFloat(w.amount).toFixed(2) %></td>
                            <td><span class="method-badge"><%= w.payment_method %></span></td>
                            <td>
                                <% if (w.status === 'approved') { %>
                                    <span class="status-badge status-verified">Approved</span>
                                <% } else { %>
                                    <span class="status-badge status-unverified">Rejected</span>
                                <% } %>
                            </td>
                            <td><%= w.approved_at ? new Date(w.approved_at).toLocaleString() : '-' %></td>
                            <td>
                                <a href="/admin/withdrawals/<%= w.id %>" class="btn btn-outline btn-sm">Details</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Approve Modal -->
<div id="approveModal" class="modal">
    <div class="modal-content" style="text-align: center;">
        <div style="width: 80px; height: 80px; background: linear-gradient(135deg, var(--success), #059669); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
            <i class="fas fa-check" style="font-size: 32px; color: white;"></i>
        </div>
        <h3>Approve Withdrawal</h3>
        <p id="approveText" style="color: var(--text-secondary); margin: 16px 0;"></p>
        <form id="approveForm" method="POST">
            <div style="display: flex; gap: 12px; margin-top: 24px;">
                <button type="button" class="btn btn-outline" style="flex: 1;" onclick="closeModal('approveModal')">Cancel</button>
                <button type="submit" class="btn btn-success" style="flex: 1;">
                    <i class="fas fa-check"></i> Confirm Approval
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Reject Modal -->
<div id="rejectModal" class="modal">
    <div class="modal-content">
        <h3 style="color: var(--danger);"><i class="fas fa-times-circle"></i> Reject Withdrawal</h3>
        <p id="rejectText" style="color: var(--text-secondary); margin: 16px 0;"></p>
        <form id="rejectForm" method="POST">
            <div class="form-group">
                <label class="form-label">Rejection Reason (Required)</label>
                <textarea name="reason" class="form-input" rows="3" placeholder="Enter reason for rejection..." required></textarea>
            </div>
            <div style="display: flex; gap: 12px; margin-top: 24px;">
                <button type="button" class="btn btn-outline" style="flex: 1;" onclick="closeModal('rejectModal')">Cancel</button>
                <button type="submit" class="btn btn-danger" style="flex: 1;">
                    <i class="fas fa-times"></i> Confirm Rejection
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function openApproveModal(id, username, amount) {
    document.getElementById('approveText').textContent = 
        `Approve $${parseFloat(amount).toFixed(2)} withdrawal for ${username}?`;
    document.getElementById('approveForm').action = `/admin/withdrawals/approve/${id}`;
    openModal('approveModal');
}

function openRejectModal(id, username, amount) {
    document.getElementById('rejectText').textContent = 
        `Reject $${parseFloat(amount).toFixed(2)} withdrawal for ${username}? Funds will be refunded.`;
    document.getElementById('rejectForm').action = `/admin/withdrawals/reject/${id}`;
    openModal('rejectModal');
}

function openModal(id) {
    document.getElementById(id).classList.add('active');
}

function closeModal(id) {
    document.getElementById(id).classList.remove('active');
}
</script>

<%- include('../partials/footer') %>