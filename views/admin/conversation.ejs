<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<style>
.conversation-container {
    max-width: 900px;
    margin: 0 auto;
}

.conversation-header {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 16px;
}

.user-avatar-large {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    font-weight: 700;
    color: white;
}

.user-details h2 {
    margin: 0 0 4px;
    font-size: 22px;
    font-weight: 700;
}

.user-details p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 14px;
}

.messages-thread {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 24px;
}

.message-item {
    padding: 24px;
    border-bottom: 1px solid var(--border);
    display: flex;
    gap: 16px;
}

.message-item:last-child {
    border-bottom: none;
}

.message-item.admin-message {
    background: rgba(139, 92, 246, 0.03);
}

.message-item.user-message {
    background: rgba(34, 197, 94, 0.03);
    flex-direction: row-reverse;
}

.message-avatar {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
}

.admin-message .message-avatar {
    background: linear-gradient(135deg, #8b5cf6, #6d28d9);
}

.user-message .message-avatar {
    background: linear-gradient(135deg, #22c55e, #16a34a);
}

.message-content {
    flex: 1;
    max-width: 80%;
}

.message-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
}

.sender-name {
    font-weight: 700;
    font-size: 15px;
}

.message-time {
    font-size: 12px;
    color: var(--text-secondary);
}

.message-type-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
}

.type-warning { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
.type-pending { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
.type-welcome { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
.type-general { background: rgba(139, 92, 246, 0.15); color: #8b5cf6; }
.type-reply { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }

.message-body {
    background: var(--secondary-bg);
    padding: 16px;
    border-radius: 12px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-primary);
}

.admin-message .message-body {
    border-left: 3px solid #8b5cf6;
}

.user-message .message-body {
    border-right: 3px solid #22c55e;
}

.reply-section {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
}

.reply-section h3 {
    margin: 0 0 16px;
    font-size: 16px;
    font-weight: 700;
}

.reply-form textarea {
    width: 100%;
    min-height: 120px;
    padding: 16px;
    background: var(--secondary-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--text-primary);
    font-size: 14px;
    resize: vertical;
    margin-bottom: 16px;
}

.reply-form button {
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: white;
    border: none;
    padding: 14px 28px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 14px;
    margin-bottom: 16px;
    transition: color 0.2s;
}

.back-link:hover {
    color: #8b5cf6;
}
</style>

<div class="dashboard">
    <a href="/admin/messages" class="back-link">
        <i class="fas fa-arrow-left"></i> Back to Messages
    </a>

    <div class="conversation-container">
        <!-- Header -->
        <div class="conversation-header">
            <div class="user-avatar-large"><%= user.username.charAt(0).toUpperCase() %></div>
            <div class="user-details">
                <h2><%= user.username %></h2>
                <p><i class="fas fa-envelope"></i> <%= user.email %> • 
                   <i class="fas fa-calendar"></i> Joined <%= new Date(user.created_at).toLocaleDateString() %></p>
            </div>
        </div>

        <!-- Messages Thread -->
        <div class="messages-thread">
            <% messages.forEach(msg => { %>
            <div class="message-item <%= msg.is_from_admin ? 'admin-message' : 'user-message' %>">
                <div class="message-avatar">
                    <%= msg.display_name.charAt(0).toUpperCase() %>
                </div>
                <div class="message-content">
                    <div class="message-header">
                        <span class="sender-name"><%= msg.display_name %></span>
                        <span class="message-type-badge type-<%= msg.type %>">
                            <% if (msg.type === 'warning') { %><i class="fas fa-exclamation-triangle"></i> Warning<% } %>
                            <% if (msg.type === 'pending') { %><i class="fas fa-clock"></i> Pending<% } %>
                            <% if (msg.type === 'welcome') { %><i class="fas fa-hand-sparkles"></i> Welcome<% } %>
                            <% if (msg.type === 'general') { %><i class="fas fa-envelope"></i> General<% } %>
                            <% if (msg.type === 'reply') { %><i class="fas fa-reply"></i> Reply<% } %>
                        </span>
                        <span class="message-time">
                            <%= new Date(msg.created_at).toLocaleString() %>
                            <% if (msg.is_from_admin && msg.status !== 'unread') { %>
                                • <%= msg.status === 'read' ? '✓ Read' : '↩ Replied' %>
                            <% } %>
                        </span>
                    </div>
                    <% if (msg.subject && msg.subject !== 'Re: Reply') { %>
                    <div style="font-weight: 600; margin-bottom: 8px; color: var(--text-primary);">
                        <%= msg.subject %>
                    </div>
                    <% } %>
                    <div class="message-body">
                        <%= msg.message %>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>

        <!-- Reply Form -->
        <div class="reply-section">
            <h3><i class="fas fa-reply"></i> Send Reply</h3>
            <form action="/admin/messages/send" method="POST" class="reply-form">
                <input type="hidden" name="user_id" value="<%= user.id %>">
                <input type="hidden" name="type" value="general">
                <input type="hidden" name="subject" value="Re: <%= messages[0]?.subject || 'Conversation' %>">
                <input type="hidden" name="parent_id" value="<%= messages[0]?.id %>">
                
                <textarea name="message" placeholder="Type your reply here..." required></textarea>
                
                <button type="submit">
                    <i class="fas fa-paper-plane"></i> Send Reply
                </button>
            </form>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>